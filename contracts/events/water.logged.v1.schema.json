{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://healthcarenow/contracts/events/water.logged.v1.schema.json",
  "title": "Water Logged Event Envelope v1",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "timestamp",
    "correlation_id",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F-]{36}$"
    },
    "event_type": {
      "type": "string",
      "const": "water.logged"
    },
    "event_version": {
      "type": "integer",
      "minimum": 1
    },
    "timestamp": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "required": ["user_id", "amount_ml", "date_string"],
      "properties": {
        "user_id": { "type": "string" },
        "amount_ml": { "type": "integer", "minimum": 1 },
        "date_string": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
